# Jork Configuration
# Copy this to .env and fill in your values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_user_id_here

# LLM Provider - choose one:
# Options: claude-cli, openai, anthropic, zhipu, custom
LLM_PROVIDER=claude-cli

# If using claude-cli (default) - no API key needed, just install Claude Code CLI
# https://claude.ai/code
# CLAUDE_CLI=/path/to/claude

# If using OpenAI or OpenAI-compatible API (zhipu, deepseek, together, etc.)
# LLM_PROVIDER=openai
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# If using Anthropic API directly (without Claude CLI)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-opus-4-6

# Jork Personality
# Name she calls herself
JORK_NAME=Jork

# Workspace - where Jork does her work
# Defaults to ./workspace inside the Jork folder
# Set to any absolute path you want Jork to work in
JORK_WORKSPACE=./workspace

# Intervals (milliseconds)
THINK_INTERVAL=300000
HEARTBEAT_INTERVAL=30000
POLL_INTERVAL=3000
INVOKE_TIMEOUT=300000
MAX_TURNS=50
